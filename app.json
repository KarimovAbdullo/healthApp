{
  "expo": {
    "name": "healthApp",
    "slug": "healthApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "healthapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karimova008.healthApp"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.karimova008.healthApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "$(PRODUCT_NAME) mashq va poza tahlili uchun kameradan foydalanadi.",
          "enableMicrophonePermission": true,
          "microphonePermissionText": "$(PRODUCT_NAME) video yozish uchun mikrofondan foydalanadi.",
          "enableFrameProcessors": true
        }
      ],
      [
        "./plugins/withMediapipeModelAssets.js",
        {
          "assetsPaths": ["./assets/models/"]
        }
      ],
      [
        "expo-navigation-bar",
        {
          "visibility": "hidden",
          "behavior": "overlay-swipe"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "resizeMode": "cover",
          "backgroundColor": "#1A0F3D"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
